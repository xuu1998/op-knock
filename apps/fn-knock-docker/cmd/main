#!/bin/bash

set -u

FILE_PATH="${TRIM_APPDEST:-}/docker/docker-compose.yaml"
DEFAULT_CONTAINER_NAME="fn-knock-docker"

resolve_container_name() {
  local container_name=""

  if [ -f "${FILE_PATH}" ]; then
    container_name="$(
      awk -F ':' '
        /^[[:space:]]*container_name[[:space:]]*:/ {
          value = $2
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
          gsub(/^["'\'']|["'\'']$/, "", value)
          print value
          exit
        }
      ' "${FILE_PATH}"
    )"
  fi

  if [ -n "${container_name}" ]; then
    echo "${container_name}"
    return 0
  fi

  echo "${DEFAULT_CONTAINER_NAME}"
}

is_docker_running() {
  local container_name
  local status

  if ! command -v docker >/dev/null 2>&1; then
    return 1
  fi

  container_name="$(resolve_container_name)"
  status="$(docker inspect --format '{{.State.Status}}' "${container_name}" 2>/dev/null || true)"
  [ "${status}" = "running" ]
}

case "${1:-}" in
  start)
    exit 0
    ;;
  stop)
    exit 0
    ;;
  status)
    if is_docker_running; then
      exit 0
    fi
    exit 3
    ;;
  *)
    exit 1
    ;;
esac
